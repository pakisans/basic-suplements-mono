# Shared build env — used by docker-compose build args and at runtime
# Copy to .env and fill in values

# Backend build-time DB (host network, before container is up)
DATABASE_URL_BUILD=postgresql://appuser:apppassword@127.0.0.1:5432/appdb

# Payload backend public URL (e.g. http://46.225.222.58:3001)
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001

# Frontend public URL (e.g. http://46.225.222.58 or http://localhost:80)
NEXT_PUBLIC_SERVER_URL=http://localhost:80

# Backend URL accessible inside Docker network (for frontend server-side calls)
PAYLOAD_URL_BUILD=http://app1:3000
NEXT_PUBLIC_PAYLOAD_URL=http://localhost:3001

# Payload secret (random string, min 32 chars)
PAYLOAD_SECRET=your-payload-secret-here

# Preview secret
PREVIEW_SECRET=your-preview-secret-here

# Revalidate secret (used by frontend webhook)
REVALIDATE_SECRET=your-revalidate-secret-here

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOKS_SIGNING_SECRET=whsec_...
